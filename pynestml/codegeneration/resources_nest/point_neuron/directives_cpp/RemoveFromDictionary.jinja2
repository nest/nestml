{#
Removes an entry from the dictionary.
#}
{%- macro RemoveFromDictionary(dict_name, key, key_as_str=false) -%}
{%-   if not nest_version.startswith("master")  %}
{%-     if key_as_str -%}
{{ dict_name }}->remove("{{ key }}");
{%-     else  -%}
{{ dict_name }}->remove({{ key }});
{%-     endif -%}
{%-   else %}
{%-     if key_as_str -%}
{{ dict_name }}.erase("{{ key }}");
{%-     else  -%}
{{ dict_name }}.erase({{ key }});
{%-     endif -%}
{%-   endif %}
{%- endmacro -%}
