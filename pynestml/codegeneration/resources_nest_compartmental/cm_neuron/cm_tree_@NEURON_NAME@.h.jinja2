class Compartment{{cm_unique_suffix}}
{
private:
  // aggragators for numerical integration
  {{ cm_scalar_t }} xx_;
  {{ cm_scalar_t }} yy_;
{%- if fp_precision == "single" %}
  double v_comp_recordable_;
{%- endif %}

public:
  // compartment index
  long comp_index;
  // parent compartment index
  long p_index;
  // tree structure indices
  Compartment{{cm_unique_suffix}}* parent;
  std::vector< Compartment{{cm_unique_suffix}} > children;

  // buffer for currents
  RingBuffer currents;
  // voltage variable
  {{ cm_scalar_t }}* v_comp;
  // electrical parameters
  {{ cm_scalar_t }} ca; // compartment capacitance [uF]
  {{ cm_scalar_t }} gc; // coupling conductance with parent (meaningless if root) [uS]
  {{ cm_scalar_t }} gl; // leak conductance of compartment [uS]
  {{ cm_scalar_t }} el; // leak current reversal potential [mV]
  // auxiliary variables for efficienchy
  {{ cm_scalar_t }}* gg0;
  {{ cm_scalar_t }}* ca__div__dt;
  {{ cm_scalar_t }}* gl__times__el;
  // for numerical integration
  {{ cm_scalar_t }}* ff;
  {{ cm_scalar_t }}* gg;
  {{ cm_scalar_t }} hh;
  // passage counter for recursion
  int n_passed;

  // constructor, destructor
  Compartment{{cm_unique_suffix}}( const long compartment_index, const long parent_index);
  Compartment{{cm_unique_suffix}}( const long compartment_index, const long parent_index,
    {{ cm_scalar_t }}* v_comp_ref, {{ cm_scalar_t }}* ca__div__dt_ref, {{ cm_scalar_t }}* gl__times__el_ref, {{ cm_scalar_t }}* gg0_ref, {{ cm_scalar_t }}* gg_ref, {{ cm_scalar_t }}* ff_ref);
  Compartment{{cm_unique_suffix}}( const long compartment_index, const long parent_index, const DictionaryDatum& compartment_params,
    {{ cm_scalar_t }}* v_comp_ref, {{ cm_scalar_t }}* ca__div__dt_ref, {{ cm_scalar_t }}* gl__times__el_ref, {{ cm_scalar_t }}* gg0_ref, {{ cm_scalar_t }}* gg_ref, {{ cm_scalar_t }}* ff_ref);
  ~Compartment{{cm_unique_suffix}}(){};

  // initialization
{%- if nest_version.startswith("v2") or nest_version.startswith("v3.1") or nest_version.startswith("v3.2") or nest_version.startswith("v3.3") %}
  void calibrate();
{%- else %}
  void pre_run_hook();
{%- endif %}
  std::map< Name, double* > get_recordables();

  // matrix construction
  void construct_matrix_coupling_elements();
{%- if fp_precision == "single" %}
  inline void sync_recordables();
{%- endif %}

  // maxtrix inversion
  inline void gather_input( const std::pair< {{ cm_scalar_t }}, {{ cm_scalar_t }} >& in );
  inline std::pair< {{ cm_scalar_t }}, {{ cm_scalar_t }} > io();
  inline {{ cm_scalar_t }} calc_v( const {{ cm_scalar_t }} v_in );
}; // Compartment

/*
Short helper functions for solving the matrix equation. Can hopefully be inlined
*/
inline void
nest::Compartment{{cm_unique_suffix}}::gather_input( const std::pair< {{ cm_scalar_t }}, {{ cm_scalar_t }} >& in )
{
  xx_ += in.first;
  yy_ += in.second;
}
inline std::pair< {{ cm_scalar_t }}, {{ cm_scalar_t }} >
nest::Compartment{{cm_unique_suffix}}::io()
{
  // include inputs from child compartments
  *gg -= xx_;
  *ff -= yy_;

  // output values
  {{ cm_scalar_t }} g_val( hh * hh / *gg );
  {{ cm_scalar_t }} f_val( *ff * hh / *gg );

  return std::make_pair( g_val, f_val );
}
inline {{ cm_scalar_t }}
nest::Compartment{{cm_unique_suffix}}::calc_v( const {{ cm_scalar_t }} v_in )
{
  // reset recursion variables
  xx_ = 0.0;
  yy_ = 0.0;

  // compute voltage
  *v_comp = ( *ff - v_in * hh ) / *gg;
{%- if fp_precision == "single" %}
  v_comp_recordable_ = static_cast< double >( *v_comp );
{%- endif %}

  return *v_comp;
}

{%- if fp_precision == "single" %}
inline void
nest::Compartment{{cm_unique_suffix}}::sync_recordables()
{
  v_comp_recordable_ = static_cast< double >( *v_comp );
}
{%- endif %}


