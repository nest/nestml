  std::map< Name, {{ cm_scalar_t }}* > get_recordables( const long compartment_idx )
  {
    std::map< Name, {{ cm_scalar_t }}* > recordables;

    // append ion channel state variables to recordables
    {%- for ion_channel_name, channel_info in chan_info.items() %}
    {{ion_channel_name}}{{channel_suffix}}.append_recordables(
      &recordables
      , compartment_idx );
    {% endfor %}

    // append concentration state variables to recordables
    {%- for concentration_name, concentration_info in conc_info.items() %}
    {{concentration_name}}{{concentration_suffix}}.append_recordables(
      &recordables
      , compartment_idx );
    {% endfor %}

    // append receptor state variables to recordables
    {%- for receptor_name, receptor_info in recs_info.items() %}
    {{receptor_name}}{{receptor_suffix}}.append_recordables(
      &recordables
      , compartment_idx );
    {% endfor %}

    // append receptor with synapse state variables to recordables
    {%- for receptor_name, receptor_info in recs_info.items() %}
    {%- for synapse_name, synapse_info in syns_info.items() %}
    {{receptor_name}}{{receptor_suffix}}_con_{{synapse_name}}.append_recordables(
      &recordables
      , compartment_idx );
    {% endfor %}
    {% endfor %}

    // append continuous input state variables to recordables
    {%- for continuous_name, continuous_info in con_in_info.items() %}
    {{continuous_name}}{{continuous_suffix}}.append_recordables(
      &recordables
      , compartment_idx );
    {% endfor %}

    return recordables;
  };

  void f_numstep( const std::vector< {{ cm_scalar_t }} >& v_comp_vec, const long& lag )
  {
    std::fill(g_vals_comp->begin(), g_vals_comp->end(), 0.0);
    std::fill(i_vals_comp->begin(), i_vals_comp->end(), 0.0);

{%- for receptor_name, receptor_info in recs_info.items() %}
    {%- set dep = namespace(needed=false) %}
    {%- for concentration_name, concentration_info in conc_info.items() %}
      {%- for inline in concentration_info["Dependencies"]["receptors"] %}
        {%- if inline.variable_name == receptor_name or inline.variable_name == receptor_name ~ receptor_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for ion_channel_name, channel_info in chan_info.items() %}
      {%- for inline in channel_info["Dependencies"]["receptors"] %}
        {%- if inline.variable_name == receptor_name or inline.variable_name == receptor_name ~ receptor_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for receptor_nm, receptor_dep_info in recs_info.items() %}
      {%- for inline in receptor_dep_info["Dependencies"]["receptors"] %}
        {%- if inline.variable_name == receptor_name or inline.variable_name == receptor_name ~ receptor_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for receptor_nm, receptor_dep_info in recs_info.items() %}
      {%- for synapse_name, synapse_info in syns_info.items() %}
        {%- for inline in synapse_info["Dependencies"]["receptors"] %}
          {%- if inline.variable_name == receptor_name or inline.variable_name == receptor_name ~ receptor_suffix %}{% set dep.needed = true %}{% endif %}
        {%- endfor %}
      {%- endfor %}
    {%- endfor %}
    {%- for continuous_name, continuous_info in con_in_info.items() %}
      {%- for inline in continuous_info["Dependencies"]["receptors"] %}
        {%- if inline.variable_name == receptor_name or inline.variable_name == receptor_name ~ receptor_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- if dep.needed %}
    {{receptor_name}}{{receptor_suffix}}.get_currents_per_compartment({{receptor_name}}{{receptor_suffix}}_shared_current);
      {%- for synapse_name, synapse_info in syns_info.items() %}
    {{receptor_name}}{{receptor_suffix}}_con_{{synapse_name}}.get_currents_per_compartment({{receptor_name}}{{receptor_suffix}}_con_{{synapse_name}}_shared_current);
    for(size_t i = 0; i < {{receptor_name}}{{receptor_suffix}}_shared_current.size(); i++){
        {{receptor_name}}{{receptor_suffix}}_shared_current[i] += {{receptor_name}}{{receptor_suffix}}_con_{{synapse_name}}_shared_current[i];
    }
      {% endfor %}
    {%- endif %}
{% endfor %}
{%- for continuous_name, continuous_info in con_in_info.items() %}
    {%- set dep = namespace(needed=false) %}
    {%- for concentration_name, concentration_info in conc_info.items() %}
      {%- for inline in concentration_info["Dependencies"]["continuous"] %}
        {%- if inline.variable_name == continuous_name or inline.variable_name == continuous_name ~ continuous_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for ion_channel_name, channel_info in chan_info.items() %}
      {%- for inline in channel_info["Dependencies"]["continuous"] %}
        {%- if inline.variable_name == continuous_name or inline.variable_name == continuous_name ~ continuous_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for receptor_name, receptor_info in recs_info.items() %}
      {%- for inline in receptor_info["Dependencies"]["continuous"] %}
        {%- if inline.variable_name == continuous_name or inline.variable_name == continuous_name ~ continuous_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for receptor_name, receptor_info in recs_info.items() %}
      {%- for synapse_name, synapse_info in syns_info.items() %}
        {%- for inline in synapse_info["Dependencies"]["continuous"] %}
          {%- if inline.variable_name == continuous_name or inline.variable_name == continuous_name ~ continuous_suffix %}{% set dep.needed = true %}{% endif %}
        {%- endfor %}
      {%- endfor %}
    {%- endfor %}
    {%- for continuous_dep_name, continuous_dep_info in con_in_info.items() %}
      {%- for inline in continuous_dep_info["Dependencies"]["continuous"] %}
        {%- if inline.variable_name == continuous_name or inline.variable_name == continuous_name ~ continuous_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- if dep.needed %}
    {{continuous_name}}{{continuous_suffix}}.get_currents_per_compartment({{continuous_name}}{{continuous_suffix}}_shared_current);
    {%- endif %}
{% endfor %}
{%- for concentration_name, concentration_info in conc_info.items() %}
    {%- set dep = namespace(needed=false) %}
    {%- for concentration_dep_name, concentration_dep_info in conc_info.items() %}
      {%- for ode in concentration_dep_info["Dependencies"]["concentrations"] %}
        {%- if ode.lhs.name == concentration_name %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for ion_channel_name, channel_info in chan_info.items() %}
      {%- for ode in channel_info["Dependencies"]["concentrations"] %}
        {%- if ode.lhs.name == concentration_name %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for receptor_name, receptor_info in recs_info.items() %}
      {%- for ode in receptor_info["Dependencies"]["concentrations"] %}
        {%- if ode.lhs.name == concentration_name %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for receptor_name, receptor_info in recs_info.items() %}
      {%- for synapse_name, synapse_info in syns_info.items() %}
        {%- for ode in synapse_info["Dependencies"]["concentrations"] %}
          {%- if ode.lhs.name == concentration_name %}{% set dep.needed = true %}{% endif %}
        {%- endfor %}
      {%- endfor %}
    {%- endfor %}
    {%- for continuous_name, continuous_info in con_in_info.items() %}
      {%- for ode in continuous_info["Dependencies"]["concentrations"] %}
        {%- if ode.lhs.name == concentration_name %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- if dep.needed %}
    {{ concentration_name }}{{concentration_suffix}}.get_concentrations_per_compartment({{concentration_name}}{{concentration_suffix}}_shared_concentration);
    {%- endif %}
{% endfor -%}
{%- for ion_channel_name, channel_info in chan_info.items() %}
    {%- set dep = namespace(needed=false) %}
    {%- for concentration_name, concentration_info in conc_info.items() %}
      {%- for inline in concentration_info["Dependencies"]["channels"] %}
        {%- if inline.variable_name == ion_channel_name or inline.variable_name == ion_channel_name ~ channel_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for ion_channel_dep_name, channel_dep_info in chan_info.items() %}
      {%- for inline in channel_dep_info["Dependencies"]["channels"] %}
        {%- if inline.variable_name == ion_channel_name or inline.variable_name == ion_channel_name ~ channel_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for receptor_name, receptor_info in recs_info.items() %}
      {%- for inline in receptor_info["Dependencies"]["channels"] %}
        {%- if inline.variable_name == ion_channel_name or inline.variable_name == ion_channel_name ~ channel_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- for receptor_name, receptor_info in recs_info.items() %}
      {%- for synapse_name, synapse_info in syns_info.items() %}
        {%- for inline in synapse_info["Dependencies"]["channels"] %}
          {%- if inline.variable_name == ion_channel_name or inline.variable_name == ion_channel_name ~ channel_suffix %}{% set dep.needed = true %}{% endif %}
        {%- endfor %}
      {%- endfor %}
    {%- endfor %}
    {%- for continuous_name, continuous_info in con_in_info.items() %}
      {%- for inline in continuous_info["Dependencies"]["channels"] %}
        {%- if inline.variable_name == ion_channel_name or inline.variable_name == ion_channel_name ~ channel_suffix %}{% set dep.needed = true %}{% endif %}
      {%- endfor %}
    {%- endfor %}
    {%- if dep.needed %}
    {{ion_channel_name}}{{channel_suffix}}.get_currents_per_compartment({{ion_channel_name}}{{channel_suffix}}_shared_current);
    {%- endif %}
{% endfor -%}

    {%- for concentration_name, concentration_info in conc_info.items() %}
    // computation of {{ concentration_name }} concentration
    {{ concentration_name }}{{concentration_suffix}}.f_numstep(v_comp_vec{% for ode in concentration_info["Dependencies"]["concentrations"] %}, {{ode.lhs.name}}{{concentration_suffix}}_shared_concentration{% endfor %}{% if concentration_info["Dependencies"]["receptors"]|length %}
                        {% endif %}{% for inline in concentration_info["Dependencies"]["receptors"] %}, {{inline.variable_name}}{{receptor_suffix}}_shared_current{% endfor %}{% if concentration_info["Dependencies"]["channels"]|length %}
                        {% endif %}{% for inline in concentration_info["Dependencies"]["channels"] %}, {{inline.variable_name}}{{channel_suffix}}_shared_current{% endfor %}{% if concentration_info["Dependencies"]["continuous"]|length %}
                        {% endif %}{% for inline in concentration_info["Dependencies"]["continuous"] %}, {{inline.variable_name}}{{continuous_suffix}}_shared_current{% endfor %});

    {% endfor -%}
    {%- for ion_channel_name, channel_info in chan_info.items() %}
    // contribution of {{ion_channel_name}} channel
    {{ion_channel_name}}{{channel_suffix}}.f_numstep(v_comp_vec{% for ode in channel_info["Dependencies"]["concentrations"] %}, {{ode.lhs.name}}{{concentration_suffix}}_shared_concentration{% endfor %}{% if channel_info["Dependencies"]["receptors"]|length %}
        {% endif %}{% for inline in channel_info["Dependencies"]["receptors"] %}, {{inline.variable_name}}{{receptor_suffix}}_shared_current{% endfor %}{% if channel_info["Dependencies"]["channels"]|length %}
        {% endif %}{% for inline in channel_info["Dependencies"]["channels"] %}, {{inline.variable_name}}{{channel_suffix}}_shared_current{% endfor %}{% if channel_info["Dependencies"]["continuous"]|length %}
        {% endif %}{% for inline in channel_info["Dependencies"]["continuous"] %}, {{inline.variable_name}}{{continuous_suffix}}_shared_current{% endfor %}
        , *i_vals_comp, *g_vals_comp);
    {% endfor -%}

    {%- for receptor_name, receptor_info in recs_info.items() %}
    // contribution of {{receptor_name}} receptors
    {{receptor_name}}{{receptor_suffix}}.f_numstep(v_comp_vec, lag {% for ode in receptor_info["Dependencies"]["concentrations"] %}, {{ode.lhs.name}}{{concentration_suffix}}_shared_concentration{% endfor %}{% if receptor_info["Dependencies"]["receptors"]|length %}
                        {% endif %}{% for inline in receptor_info["Dependencies"]["receptors"] %}, {{inline.variable_name}}{{receptor_suffix}}_shared_current{% endfor %}{% if receptor_info["Dependencies"]["channels"]|length %}
                        {% endif %}{% for inline in receptor_info["Dependencies"]["channels"] %}, {{inline.variable_name}}{{channel_suffix}}_shared_current{% endfor %}{% if receptor_info["Dependencies"]["continuous"]|length %}
                        {% endif %}{% for inline in receptor_info["Dependencies"]["continuous"] %}, {{inline.variable_name}}{{continuous_suffix}}_shared_current{% endfor %}
                        , *i_vals_comp, *g_vals_comp);
    {% endfor -%}

    {%- for receptor_name, receptor_info in recs_info.items() %}
    {%- for synapse_name, synapse_info in syns_info.items() %}
    // contribution of {{receptor_name}}_{{synapse_name}} receptors
    {%- with  %}
    {%- set conc_dep = set(receptor_info["Dependencies"]["concentrations"]).union(synapse_info["Dependencies"]["concentrations"])%}
    {%- set rec_dep = set(receptor_info["Dependencies"]["receptors"]).union(synapse_info["Dependencies"]["receptors"])%}
    {%- set chan_dep = set(receptor_info["Dependencies"]["channels"]).union(synapse_info["Dependencies"]["channels"])%}
    {%- set con_in_dep = set(receptor_info["Dependencies"]["continuous"]).union(synapse_info["Dependencies"]["continuous"])%}
    {{receptor_name}}{{receptor_suffix}}_con_{{synapse_name}}.f_numstep(v_comp_vec, lag {% for ode in conc_dep %}, {{ode.lhs.name}}{{concentration_suffix}}_shared_concentration{% endfor %}{% if rec_dep|length %}
                        {% endif %}{% for inline in rec_dep %}, {{inline.variable_name}}{{receptor_suffix}}_shared_current{% endfor %}{% if chan_dep|length %}
                        {% endif %}{% for inline in chan_dep %}, {{inline.variable_name}}{{channel_suffix}}_shared_current{% endfor %}{% if con_in_dep|length %}
                        {% endif %}{% for inline in con_in_dep %}, {{inline.variable_name}}{{continuous_suffix}}_shared_current{% endfor %}
                        , *i_vals_comp, *g_vals_comp);
    {%- endwith %}
    {% endfor -%}
    {% endfor -%}

    {%- for continuous_name, continuous_info in con_in_info.items() %}
    // contribution of {{continuous_name}} continuous inputs
    {{continuous_name}}{{continuous_suffix}}.f_numstep(v_comp_vec, lag {% for ode in continuous_info["Dependencies"]["concentrations"] %}, {{ode.lhs.name}}{{concentration_suffix}}_shared_concentration{% endfor %}{% if continuous_info["Dependencies"]["receptors"]|length %}
                        {% endif %}{% for inline in continuous_info["Dependencies"]["receptors"] %}, {{inline.variable_name}}{{receptor_suffix}}_shared_current{% endfor %}{% if continuous_info["Dependencies"]["channels"]|length %}
                        {% endif %}{% for inline in continuous_info["Dependencies"]["channels"] %}, {{inline.variable_name}}{{channel_suffix}}_shared_current{% endfor %}{% if continuous_info["Dependencies"]["continuous"]|length %}
                        {% endif %}{% for inline in continuous_info["Dependencies"]["continuous"] %}, {{inline.variable_name}}{{continuous_suffix}}_shared_current{% endfor %}
                        , *i_vals_comp, *g_vals_comp);
    {% endfor -%}
  };

  void f_self_spike(){
    {%- for receptor_name, receptor_info in recs_info.items() %}
        {%- for synapse_name, synapse_info in syns_info.items() %}
    {{receptor_name}}{{receptor_suffix}}_con_{{synapse_name}}.postsynaptic_synaptic_processing();
    {%- if receptor_info["Blocks"] and receptor_info["Blocks"]["SelfSpikesFunction"] %}
    {{receptor_name}}{{receptor_suffix}}_con_{{synapse_name}}.f_self_spike();
    {%- endif %}
        {% endfor -%}
    {%- if receptor_info["Blocks"] and receptor_info["Blocks"]["SelfSpikesFunction"] %}
    {{receptor_name}}{{receptor_suffix}}.f_self_spike();
    {%- endif %}
    {% endfor -%}
    {%- for ion_channel_name, channel_info in chan_info.items() %}
    {%- if channel_info["Blocks"] and channel_info["Blocks"]["SelfSpikesFunction"] %}
    {{ion_channel_name}}{{channel_suffix}}.f_self_spike();
    {%- endif %}
    {% endfor -%}
    {%- for concentration_name, concentration_info in conc_info.items() %}
    {%- if concentration_info["Blocks"] and concentration_info["Blocks"]["SelfSpikesFunction"] %}
    {{concentration_name}}{{concentration_suffix}}.f_self_spike();
    {%- endif %}
    {% endfor -%}
    {%- for continuous_name, continuous_info in con_in_info.items() %}
    {%- if continuous_info["Blocks"] and continuous_info["Blocks"]["SelfSpikesFunction"] %}
    {{continuous_name}}{{continuous_suffix}}.f_self_spike();
    {%- endif %}
    {% endfor -%}
  };
};

