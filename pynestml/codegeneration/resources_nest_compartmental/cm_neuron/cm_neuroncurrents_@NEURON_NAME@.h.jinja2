private:

  // dendritic delay buffer class
    class TimerDeque {
    public:
        TimerDeque({{ cm_scalar_t }} delay) :
            countdown(nest::Time::delay_ms_to_steps(delay))
            {}

        void push({{ cm_scalar_t }} value) {
            int local_countdown = countdown - total_countdown;
            total_countdown = countdown;
            dq.push_back(std::make_pair(local_countdown, value));
        }

        {{ cm_scalar_t }} tick() {
            if (!dq.empty()) {
                dq.front().first--;
                total_countdown--;
                if (dq.front().first == 0) {
                    {{ cm_scalar_t }} value = dq.front().second;
                    dq.pop_front();
                    return value;
                }
            }
            return 0;
        }

    private:
        std::deque<std::pair<int, {{ cm_scalar_t }}>> dq;

        const int countdown;
        int total_countdown = 0;
    };

  // delayed spikes queue
  std::vector<TimerDeque> delayed_spikes;

