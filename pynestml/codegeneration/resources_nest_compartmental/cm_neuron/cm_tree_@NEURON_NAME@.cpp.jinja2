/**
 * Construct the matrix equation to be solved to advance the model one timestep
 */
void
nest::CompTree{{cm_unique_suffix}}::construct_matrix( const long lag )
{
  // compute all channel currents, receptor currents, and input currents
  neuron_currents.f_numstep( v_comp_vec, lag );

  #pragma omp simd
  for( size_t i = 0; i < v_comp_vec.size(); i++ ){
    // passive current left hand side
    gg_vec[i] = gg0_vec[i];
    // passive currents right hand side
    ff_vec[i] = ca__div__dt_vec[i] * v_comp_vec[i] + gl__times__el_vec[i];

    // add all currents to compartment
    gg_vec[i] += (*g_vals)[i];
    ff_vec[i] += (*i_vals)[i];
  }
  for ( auto compartment_it = compartments_.begin(); compartment_it != compartments_.end(); ++compartment_it )
  {
    ( *compartment_it )->construct_matrix_coupling_elements();
  }
}

/**
 * Solve matrix with O(n) algorithm
 */
void
nest::CompTree{{cm_unique_suffix}}::solve_matrix()
{
  // start the down sweep (puts to zero the sub diagonal matrix elements)
  solve_matrix_downsweep();

  // do up sweep to set voltages
  solve_matrix_upsweep();
}

void nest::CompTree{{cm_unique_suffix}}::compute_sweeping_order( std::vector< Compartment{{cm_unique_suffix}}* > parallel_comps )
{
    if(parallel_comps.size() > 0){
        sweeping_order.push_back(parallel_comps);

        std::vector< Compartment{{cm_unique_suffix}}* > next_parallel_comps;
        for(size_t i = 0; i < parallel_comps.size(); i++){
            if(parallel_comps[i]->parent != nullptr){
                Compartment{{cm_unique_suffix}}* parent = parallel_comps[i]->parent;
                parent->n_passed++;
                if ( parent->n_passed == int( parent->children.size() ) ){
                    parent->n_passed = 0;
                    next_parallel_comps.push_back(parent);
                }
            }
        }
        compute_sweeping_order(next_parallel_comps);
    }
}

void nest::CompTree{{cm_unique_suffix}}::create_tree_data_soa_by_sweeping_order(){
    const std::size_t n_comp = compartments_.size();
    sweeping_order_idx_.clear();
    sweeping_order_idx_.reserve(sweeping_order.size());

    for(std::size_t level = 0; level < sweeping_order.size(); level++){
        const std::vector< Compartment{{cm_unique_suffix}}* >& sweep_level = sweeping_order[level];
        std::vector< std::size_t > level_idx;
        level_idx.reserve(sweep_level.size());
        for(std::size_t i = 0; i < sweep_level.size(); i++){
            level_idx.push_back(std::size_t(sweep_level[i]->comp_index));
        }
        sweeping_order_idx_.push_back(level_idx);
    }

    parent_idx_.assign(n_comp, 0);
    has_parent_.assign(n_comp, false);
    hh_vec_.assign(n_comp, 0.0);
    child_offsets_.assign(n_comp + 1, 0);
    child_indices_.clear();

    for(std::size_t comp_id = 0; comp_id < n_comp; comp_id++){
        Compartment{{cm_unique_suffix}}* compartment = compartments_[comp_id];
        if(compartment->parent != nullptr){
            has_parent_[comp_id] = true;
            parent_idx_[comp_id] = std::size_t(compartment->parent->comp_index);
            // matrix off diagonal element used in Hines sweeps
            hh_vec_[comp_id] = -compartment->gc;
        }
    }

    std::size_t child_count_prefix = 0;
    for(std::size_t comp_id = 0; comp_id < n_comp; comp_id++){
        child_offsets_[comp_id] = child_count_prefix;
        child_count_prefix += compartments_[comp_id]->children.size();
    }
    child_offsets_[n_comp] = child_count_prefix;
    child_indices_.resize(child_count_prefix);

    for(std::size_t comp_id = 0; comp_id < n_comp; comp_id++){
        std::size_t out_idx = child_offsets_[comp_id];
        const std::vector< Compartment{{cm_unique_suffix}} >& children = compartments_[comp_id]->children;
        for(std::size_t child_idx = 0; child_idx < children.size(); child_idx++){
            child_indices_[out_idx++] = std::size_t(children[child_idx].comp_index);
        }
    }

    sweep_g_out_.assign(n_comp, 0.0);
    sweep_f_out_.assign(n_comp, 0.0);
}

void
nest::CompTree{{cm_unique_suffix}}::solve_matrix_downsweep()
{
    // Base level (leaf compartments): no child accumulation, but their io()
    // outputs are needed by the next level.
    if(!sweeping_order_idx_.empty()){
        const std::vector< std::size_t >& leaf_level = sweeping_order_idx_[0];
        #pragma omp simd
        for(std::size_t i = 0; i < leaf_level.size(); i++){
            const std::size_t comp_id = leaf_level[i];
            if(has_parent_[comp_id]){
                const {{ cm_scalar_t }} hh = hh_vec_[comp_id];
                sweep_g_out_[comp_id] = hh * hh / gg_vec[comp_id];
                sweep_f_out_[comp_id] = ff_vec[comp_id] * hh / gg_vec[comp_id];
            }
        }
    }

    for(std::size_t level = 1; level < sweeping_order_idx_.size(); level++){
        const std::vector< std::size_t >& sweep_level = sweeping_order_idx_[level];
        #pragma omp simd
        for(std::size_t i = 0; i < sweep_level.size(); i++){
            const std::size_t comp_id = sweep_level[i];
            {{ cm_scalar_t }} xx = 0.0;
            {{ cm_scalar_t }} yy = 0.0;

            for(std::size_t idx = child_offsets_[comp_id]; idx < child_offsets_[comp_id + 1]; idx++){
                const std::size_t child_id = child_indices_[idx];
                xx += sweep_g_out_[child_id];
                yy += sweep_f_out_[child_id];
            }

            gg_vec[comp_id] -= xx;
            ff_vec[comp_id] -= yy;

            if(has_parent_[comp_id]){
                const {{ cm_scalar_t }} hh = hh_vec_[comp_id];
                sweep_g_out_[comp_id] = hh * hh / gg_vec[comp_id];
                sweep_f_out_[comp_id] = ff_vec[comp_id] * hh / gg_vec[comp_id];
            }
        }
    }
}

void
nest::CompTree{{cm_unique_suffix}}::solve_matrix_upsweep()
{
    const std::size_t root_id = std::size_t(root_.comp_index);
    v_comp_vec[root_id] = ff_vec[root_id] / gg_vec[root_id];

    for(std::size_t level = sweeping_order_idx_.size() - 1; level > 0; level--){
        const std::vector< std::size_t >& sweep_level = sweeping_order_idx_[level - 1];
        #pragma omp simd
        for(std::size_t i = 0; i < sweep_level.size(); i++){
            const std::size_t comp_id = sweep_level[i];
            const std::size_t parent_id = parent_idx_[comp_id];
            const {{ cm_scalar_t }} vv_parent = v_comp_vec[parent_id];
            v_comp_vec[comp_id] = (ff_vec[comp_id] - vv_parent * hh_vec_[comp_id]) / gg_vec[comp_id];
        }
    }
}

/**
 * Print the tree graph
 */
void
nest::CompTree{{cm_unique_suffix}}::print_tree() const
{
  // loop over all compartments
  std::printf( ">>> CM tree with %d compartments <<<\n", int( compartments_.size() ) );
  for ( int ii = 0; ii < int( compartments_.size() ); ++ii )
  {
    Compartment{{cm_unique_suffix}}* compartment = compartments_[ ii ];
    std::cout << "    Compartment{{cm_unique_suffix}} " << compartment->comp_index << ": ";
    std::cout << "C_m = " << compartment->ca << " nF, ";
    std::cout << "g_L = " << compartment->gl << " uS, ";
    std::cout << "e_L = " << compartment->el << " mV, ";
    if ( compartment->parent != nullptr )
    {
      std::cout << "Parent " << compartment->parent->comp_index << " --> ";
      std::cout << "g_c = " << compartment->gc << " uS, ";
    }
    std::cout << std::endl;
  }
  std::cout << std::endl;
}
