void
{%- if nest_version.startswith("main") or nest_version_dict and ((nest_version_dict["major"] == 3 and nest_version_dict["minor"] > 3) or nest_version_dict["major"] > 3) %}
nest::Compartment{{cm_unique_suffix}}::pre_run_hook()
{%- else %}
nest::Compartment{{cm_unique_suffix}}::calibrate()
{%- endif %}
{

  const {{ cm_scalar_t }} dt = Time::get_resolution().get_ms();
  // used in vectorized passive loop
  *ca__div__dt = ca / dt;
  *gl__times__el = gl * el;
  *gg0 = *ca__div__dt + gl;
}

