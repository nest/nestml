          {%- else %}
      {{state_variable_name}}[i] += s_val[i] * {{ vector_printer.print(state_variable_info["init_expression"], "i", non_vec_vars) }};
          {%- endif %}
      {%- endfor %}
      {%- endfor %}

      // total current
      // this expression should be the transformed inline expression

      i_tot_{{receptor_name}}[i] = {{ vector_printer.print(receptor_info["root_expression"], "i", non_vec_vars) }};

      // derivative of that expression
      // voltage derivative of total current
      // compute derivative with respect to current with sympy
      {{ cm_scalar_t }} d_i_tot_dv = {{ vector_printer.print(receptor_info["inline_derivative"], "i", non_vec_vars) }};

      // for numerical integration
      g_vals_{{receptor_name}}[i] = -d_i_tot_dv;
      i_vals_{{receptor_name}}[i] = i_tot_{{receptor_name}}[i] - d_i_tot_dv * v_comp;
  }

  if(con_area_count > 0){
      for(std::size_t con_area_index = 0; con_area_index < con_area_count-1; con_area_index++){
          std::size_t con_start = con_area[con_area_index].first;
          std::size_t con_end = con_area[con_area_index+1].first;
          int offset = con_area[con_area_index].second;

          #pragma omp simd
          for(std::size_t rec_id = con_start; rec_id < con_end; rec_id++){
              g_val[rec_id + offset] += g_vals_{{receptor_name}}[rec_id];
              i_val[rec_id + offset] += i_vals_{{receptor_name}}[rec_id];
          }
      }

      std::size_t con_start = con_area[con_area_count-1].first;
      int offset = con_area[con_area_count-1].second;

      #pragma omp simd
      for(std::size_t rec_id = con_start; rec_id < neuron_{{ receptor_name }}_receptor_count; rec_id++){
          g_val[rec_id + offset] += g_vals_{{receptor_name}}[rec_id];
          i_val[rec_id + offset] += i_vals_{{receptor_name}}[rec_id];
      }
  }

  {%- if receptor_info["Blocks"] and receptor_info["Blocks"]["UpdateBlock"] %}
  f_update();
  {%- endif %}
}

