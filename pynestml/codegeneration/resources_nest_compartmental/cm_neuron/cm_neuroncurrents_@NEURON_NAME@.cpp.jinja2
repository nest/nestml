// Required for numerical stability in single precision: keep propagator
// exponents in a bounded interval so exp cannot overflow.
__attribute__((always_inline)) inline float
bounded_propagator_expf(const float x)
{
    const float xc = (x < -10.0f) ? -10.0f : ((x > 0.0f) ? 0.0f : x);
    return std::exp(xc);
}
