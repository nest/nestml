void nest::{{ion_channel_name}}{{cm_unique_suffix}}::f_numstep(const std::vector< {{ cm_scalar_t }} >& shared_v_comp{% for ode in channel_info["Dependencies"]["concentrations"] %}, const std::vector< {{ cm_scalar_t }} >& shared_{{ode.lhs.name}}{% endfor %}{% if channel_info["Dependencies"]["receptors"]|length %}
                        {% endif %}{% for inline in channel_info["Dependencies"]["receptors"] %}, const std::vector< {{ cm_scalar_t }} >& shared_{{inline.variable_name}}{% endfor %}{% if channel_info["Dependencies"]["channels"]|length %}
                        {% endif %}{% for inline in channel_info["Dependencies"]["channels"] %}, const std::vector< {{ cm_scalar_t }} >& shared_{{inline.variable_name}}{% endfor %}{% if channel_info["Dependencies"]["continuous"]|length %}
                        {% endif %}{% for inline in channel_info["Dependencies"]["continuous"] %}, const std::vector< {{ cm_scalar_t }} >& shared_{{inline.variable_name}}{% endfor %}
                        , std::vector< {{ cm_scalar_t }} >& i_val, std::vector< {{ cm_scalar_t }} >& g_val)
{
        {% if "time_resolution_var" in channel_info %}
    {{ cm_scalar_t }} {{ printer_no_origin.print(channel_info["time_resolution_var"]) }} = Time::get_resolution().get_ms();
    {% endif %}

    double self_spikes = *self_spikes_p;

        {%- for function in channel_info["Functions"] %}
        {{render_lambda(function, printer_no_origin)}}
        {%- endfor %}

    std::size_t con_area_count = con_area.size();
    if(con_area_count > 0){
        for(std::size_t con_area_index = 0; con_area_index < con_area_count-1; con_area_index++){
            std::size_t con_start = con_area[con_area_index].first;
            std::size_t con_end = con_area[con_area_index+1].first;
            int offset = con_area[con_area_index].second;

            #pragma omp simd
            for(std::size_t chan_id = con_start; chan_id < con_end; chan_id++){
                v_comp_chan_[chan_id] = shared_v_comp[chan_id + offset];
                {%- for ode in channel_info["Dependencies"]["concentrations"] %}
                dep_conc_{{ode.lhs.name}}_chan_[chan_id] = shared_{{ode.lhs.name}}[chan_id + offset];
                {%- endfor %}
                {%- for inline in channel_info["Dependencies"]["receptors"] %}
                dep_rec_{{inline.variable_name}}_chan_[chan_id] = shared_{{inline.variable_name}}[chan_id + offset];
                {%- endfor %}
                {%- for inline in channel_info["Dependencies"]["channels"] %}
                dep_chan_{{inline.variable_name}}_chan_[chan_id] = shared_{{inline.variable_name}}[chan_id + offset];
                {%- endfor %}
                {%- for inline in channel_info["Dependencies"]["continuous"] %}
                dep_con_in_{{inline.variable_name}}_chan_[chan_id] = shared_{{inline.variable_name}}[chan_id + offset];
                {%- endfor %}
            }
        }

        std::size_t con_start = con_area[con_area_count-1].first;
        int offset = con_area[con_area_count-1].second;

        #pragma omp simd
        for(std::size_t chan_id = con_start; chan_id < neuron_{{ ion_channel_name }}_channel_count; chan_id++){
            v_comp_chan_[chan_id] = shared_v_comp[chan_id + offset];
            {%- for ode in channel_info["Dependencies"]["concentrations"] %}
            dep_conc_{{ode.lhs.name}}_chan_[chan_id] = shared_{{ode.lhs.name}}[chan_id + offset];
            {%- endfor %}
            {%- for inline in channel_info["Dependencies"]["receptors"] %}
            dep_rec_{{inline.variable_name}}_chan_[chan_id] = shared_{{inline.variable_name}}[chan_id + offset];
            {%- endfor %}
            {%- for inline in channel_info["Dependencies"]["channels"] %}
            dep_chan_{{inline.variable_name}}_chan_[chan_id] = shared_{{inline.variable_name}}[chan_id + offset];
            {%- endfor %}
            {%- for inline in channel_info["Dependencies"]["continuous"] %}
            dep_con_in_{{inline.variable_name}}_chan_[chan_id] = shared_{{inline.variable_name}}[chan_id + offset];
            {%- endfor %}
        }
    }

        #pragma omp simd
        for(std::size_t i = 0; i < neuron_{{ ion_channel_name }}_channel_count; i++){
            {{ cm_scalar_t }} v_comp = v_comp_chan_[i];
            {% for ode in channel_info["Dependencies"]["concentrations"] %}
            {{ cm_scalar_t }} {{ode.lhs.name}} = dep_conc_{{ode.lhs.name}}_chan_[i];
            {% endfor %}
            {% for inline in channel_info["Dependencies"]["receptors"] %}
            {{ cm_scalar_t }} {{inline.variable_name}} = dep_rec_{{inline.variable_name}}_chan_[i];
            {% endfor %}
            {% for inline in channel_info["Dependencies"]["channels"] %}
            {{ cm_scalar_t }} {{inline.variable_name}} = dep_chan_{{inline.variable_name}}_chan_[i];
            {% endfor %}
            {% for inline in channel_info["Dependencies"]["continuous"] %}
            {{ cm_scalar_t }} {{inline.variable_name}} = dep_con_in_{{inline.variable_name}}_chan_[i];
            {% endfor %}

        {%- for replacement, expression in channel_info["cse_function_replacements"].items() %}
            {{ cm_scalar_t }} {{ replacement }} = {{ vector_printer.print(expression, "i", non_vec_vars) }};
        {%- endfor %}
        {%- for replacement, expression in channel_info["cse_body_replacements"].items() %}
            {{ cm_scalar_t }} {{ replacement }} = {{ vector_printer.print(expression, "i", non_vec_vars) }};
        {%- endfor %}

        {%- for variable_info in channel_info["SecondaryInlineExpressions"] %}
        {%- if variable_info.is_recordable %}
        {%- set variable = variable_info.variable_name %}
        {%- set rhs_expression = variable_info.expression %}
        {{ variable }}[i] = {{ vector_printer.print(rhs_expression, "i", non_vec_vars) }};
        {%- endif %}
        {%- endfor %}

        {%- for convolution, convolution_info in channel_info["convolutions"].items() %}
      {%- for state_variable_name, state_variable_info in convolution_info["analytic_solution"]["kernel_states"].items() %}
      {{state_variable_name}}[i] = {{ vector_printer.print(state_variable_info["update_expression"], "i", non_vec_vars) }};
      {{state_variable_name}}[i] += self_spikes * {{ vector_printer.print(state_variable_info["init_expression"], "i", non_vec_vars) }};
      {%- endfor %}
      {%- endfor %}

        {%- for ode_variable, ode_info in channel_info["ODEs"].items() %}
            {%- for propagator, propagator_info in ode_info["transformed_solutions"][0]["propagators"].items() %}
            {{ cm_scalar_t }} {{ propagator }} = {{ vector_printer.print(propagator_info["init_expression"], "i", non_vec_vars) }};
            {%- endfor %}
            {%- for state, state_solution_info in ode_info["transformed_solutions"][0]["states"].items() %}
            {{state}}[i] = {{ vector_printer.print(state_solution_info["update_expression"], "i", non_vec_vars) }};
            {%- endfor %}
        {%- endfor %}

        {%- set inline_expression = channel_info["root_expression"] %}
        {%- set inline_expression_d = channel_info["inline_derivative"] %}

            // compute the conductance of the {{ion_channel_name}} channel
            i_tot_{{ion_channel_name}}[i] = {{ vector_printer.print(inline_expression, "i", non_vec_vars) }};

            // derivative
            {{ cm_scalar_t }} d_i_tot_dv = {{ vector_printer.print(inline_expression_d, "i", non_vec_vars) }};
            g_vals_{{ion_channel_name}}[i] = -d_i_tot_dv;
            i_vals_{{ion_channel_name}}[i] = i_tot_{{ion_channel_name}}[i] - d_i_tot_dv * v_comp;
        }

    if(con_area_count > 0){
        for(std::size_t con_area_index = 0; con_area_index < con_area_count-1; con_area_index++){
            std::size_t con_start = con_area[con_area_index].first;
            std::size_t con_end = con_area[con_area_index+1].first;
            int offset = con_area[con_area_index].second;

            #pragma omp simd
            for(std::size_t chan_id = con_start; chan_id < con_end; chan_id++){
                g_val[chan_id + offset] += g_vals_{{ion_channel_name}}[chan_id];
                i_val[chan_id + offset] += i_vals_{{ion_channel_name}}[chan_id];
            }
        }

        std::size_t con_start = con_area[con_area_count-1].first;
        int offset = con_area[con_area_count-1].second;

        #pragma omp simd
        for(std::size_t chan_id = con_start; chan_id < neuron_{{ ion_channel_name }}_channel_count; chan_id++){
            g_val[chan_id + offset] += g_vals_{{ion_channel_name}}[chan_id];
            i_val[chan_id + offset] += i_vals_{{ion_channel_name}}[chan_id];
        }
    }
    {%- if channel_info["Blocks"] and channel_info["Blocks"]["UpdateBlock"] %}
    f_update();
    {%- endif %}
}

