                        {% endif %}{% for inline in rec_dep %}, const std::vector< {{ cm_scalar_t }} >& shared_{{inline.variable_name}}{% endfor %}{% if chan_dep|length %}
                        {% endif %}{% for inline in chan_dep %}, const std::vector< {{ cm_scalar_t }} >& shared_{{inline.variable_name}}{% endfor %}{% if con_in_dep|length %}
                        {% endif %}{% for inline in con_in_dep %}, const std::vector< {{ cm_scalar_t }} >& shared_{{inline.variable_name}}{% endfor %}
                        , std::vector< {{ cm_scalar_t }} >& i_val, std::vector< {{ cm_scalar_t }} >& g_val)
{

    double self_spikes = *self_spikes_p;

    for(std::size_t i = 0; i < neuron_{{ receptor_name }}_receptor_count; i++){
      // get spikes
      s_val[i] = {{receptor_info["buffer_name"]}}_[i]->get_value( lag );
    }
        //synaptic processing:
        //presynaptic spike processing
  #pragma omp simd
  for(std::size_t i = 0; i < neuron_{{ receptor_name }}_receptor_count; i++){
      if(s_val[i]!=0) {
            {%- set function = synapse_info["PreSpikeFunction"] %}
            {%-   filter indent(2,True) %}
            {%-   with ast = function.get_stmts_body() %}
                {%- set printer = vector_printer.printer(black_list = non_vec_vars) %}
            {%-     include "cm_directives_cpp/StmtsBody.jinja2" %}
            {%-   endwith %}
            {%-   endfilter %}
      }
  }
    //presynaptic spike processing end
        //continuous synaptic processing
    #pragma omp simd
    for(std::size_t i = 0; i < neuron_{{ receptor_name }}_receptor_count; i++){
        //inlines and convolutions
    {%- for convolution, convolution_info in synapse_info["convolutions"].items() %}
      {%- for state_variable_name, state_variable_info in convolution_info["analytic_solution"]["kernel_states"].items() %}
      {{state_variable_name}}[i] = {{ vector_printer.print(state_variable_info["update_expression"], "i", non_vec_vars) }};
      {{state_variable_name}}[i] += {%- if convolution_info["post_port"] %}self_spikes{%- else %}s_val[i]{%- endif %} * {{ vector_printer.print(state_variable_info["init_expression"], "i", non_vec_vars) }};
      {%- endfor %}
    {%- endfor %}
    {%- for inline, inline_info in synapse_info["Inlines"].items() %}
        {{ inline }}[i] = {{ vector_printer.print(inline_info["inline_expression"].get_expression(), "i", non_vec_vars) }};
    {%- endfor %}
        //update block
        {%- if synapse_info["UpdateBlock"] %}
        {%- set function = synapse_info["UpdateBlock"] %}
        {%-   filter indent(2,True) %}
        {%-   with ast = function.get_stmts_body() %}
        {%- set printer = vector_printer.printer(black_list = non_vec_vars) %}
        {%-     include "cm_directives_cpp/StmtsBody.jinja2" %}
        {%-   endwith %}
        {%-   endfilter %}
        {%- endif %}
    }

    {% if synapse_info["ODEs"].items()|length %}
    {{ cm_scalar_t }} {{ printer_no_origin.print(synapse_info["time_resolution_var"]) }} = Time::get_resolution().get_ms();
    {% endif %}

    #pragma omp simd
    for(std::size_t i = 0; i < neuron_{{ receptor_name }}_receptor_count; i++){
        {%- for ode_variable, ode_info in synapse_info["ODEs"].items() %}
          {%- for propagator, propagator_info in ode_info["transformed_solutions"][0]["propagators"].items() %}
      {{ cm_scalar_t }} {{ propagator }} = {{ vector_printer.print(propagator_info["init_expression"], "i", non_vec_vars) }};
          {%- endfor %}
          {%- for state, state_solution_info in ode_info["transformed_solutions"][0]["states"].items() %}
      {{state}}[i] = {{ vector_printer.print(state_solution_info["update_expression"], "i", non_vec_vars) }};
          {%- endfor %}
      {%- endfor %}
    }

    #pragma omp simd
    for(std::size_t i = 0; i < neuron_{{ receptor_name }}_receptor_count; i++){
        // receive (potentially) delayed spikes
        s_val[i] = delayed_spikes[i].tick();
    }

    {% if receptor_info["ODEs"].items()|length %}
  {{ cm_scalar_t }} {{ printer_no_origin.print(receptor_info["analytic_helpers"]["__h"]["ASTVariable"]) }} = Time::get_resolution().get_ms();
    {% endif %}

        {%- for function in receptor_info["Functions"] %}
        {{render_lambda(function, printer_no_origin)}}
        {%- endfor %}

  std::size_t con_area_count = con_area.size();
  if(con_area_count > 0){
      for(std::size_t con_area_index = 0; con_area_index < con_area_count-1; con_area_index++){
          std::size_t con_start = con_area[con_area_index].first;
          std::size_t con_end = con_area[con_area_index+1].first;
          int offset = con_area[con_area_index].second;
          #pragma omp simd
          for(std::size_t rec_id = con_start; rec_id < con_end; rec_id++){
              v_comp_rec_[rec_id] = shared_v_comp[rec_id + offset];
              {%- for ode in conc_dep %}
              dep_conc_{{ode.lhs.name}}_rec_[rec_id] = shared_{{ode.lhs.name}}[rec_id + offset];
              {%- endfor %}
              {%- for inline in rec_dep %}
              dep_rec_{{inline.variable_name}}_rec_[rec_id] = shared_{{inline.variable_name}}[rec_id + offset];
              {%- endfor %}
              {%- for inline in chan_dep %}
              dep_chan_{{inline.variable_name}}_rec_[rec_id] = shared_{{inline.variable_name}}[rec_id + offset];
              {%- endfor %}
              {%- for inline in con_in_dep %}
              dep_con_in_{{inline.variable_name}}_rec_[rec_id] = shared_{{inline.variable_name}}[rec_id + offset];
              {%- endfor %}
          }
      }
      std::size_t con_start = con_area[con_area_count-1].first;
      int offset = con_area[con_area_count-1].second;
      #pragma omp simd
      for(std::size_t rec_id = con_start; rec_id < neuron_{{ receptor_name }}_receptor_count; rec_id++){
          v_comp_rec_[rec_id] = shared_v_comp[rec_id + offset];
          {%- for ode in conc_dep %}
          dep_conc_{{ode.lhs.name}}_rec_[rec_id] = shared_{{ode.lhs.name}}[rec_id + offset];
          {%- endfor %}
          {%- for inline in rec_dep %}
          dep_rec_{{inline.variable_name}}_rec_[rec_id] = shared_{{inline.variable_name}}[rec_id + offset];
          {%- endfor %}
          {%- for inline in chan_dep %}
          dep_chan_{{inline.variable_name}}_rec_[rec_id] = shared_{{inline.variable_name}}[rec_id + offset];
          {%- endfor %}
          {%- for inline in con_in_dep %}
          dep_con_in_{{inline.variable_name}}_rec_[rec_id] = shared_{{inline.variable_name}}[rec_id + offset];
          {%- endfor %}
      }
  }

      //update ODE state variable
  #pragma omp simd
  for(std::size_t i = 0; i < neuron_{{ receptor_name }}_receptor_count; i++){
            {{ cm_scalar_t }} v_comp = v_comp_rec_[i];
            {% for ode in conc_dep %}
            {{ cm_scalar_t }} {{ode.lhs.name}} = dep_conc_{{ode.lhs.name}}_rec_[i];
            {% endfor %}
            {% for inline in rec_dep %}
            {{ cm_scalar_t }} {{inline.variable_name}} = dep_rec_{{inline.variable_name}}_rec_[i];
            {% endfor %}
            {% for inline in chan_dep %}
            {{ cm_scalar_t }} {{inline.variable_name}} = dep_chan_{{inline.variable_name}}_rec_[i];
            {% endfor %}
            {% for inline in con_in_dep %}
            {{ cm_scalar_t }} {{inline.variable_name}} = dep_con_in_{{inline.variable_name}}_rec_[i];
            {% endfor %}

        {%- for replacement, expression in receptor_info["cse_function_replacements"].items() %}
            {{ cm_scalar_t }} {{ replacement }} = {{ vector_printer.print(expression, "i", non_vec_vars) }};
        {%- endfor %}
        {%- for replacement, expression in receptor_info["cse_body_replacements"].items() %}
            {{ cm_scalar_t }} {{ replacement }} = {{ vector_printer.print(expression, "i", non_vec_vars) }};
        {%- endfor %}

        {%- for variable_info in receptor_info["SecondaryInlineExpressions"] %}
        {%- if variable_info.is_recordable %}
        {%- set variable = variable_info.variable_name %}
        {%- set rhs_expression = variable_info.expression %}
        {{ variable }}[i] = {{ vector_printer.print(rhs_expression, "i", non_vec_vars) }};
        {%- endif %}
        {%- endfor %}

      {%- for ode_variable, ode_info in receptor_info["ODEs"].items() %}
          {%- for propagator, propagator_info in ode_info["transformed_solutions"][0]["propagators"].items() %}
      {{ cm_scalar_t }} {{ propagator }} = {{ vector_printer.print(propagator_info["init_expression"], "i", non_vec_vars) }};
          {%- endfor %}
          {%- for state, state_solution_info in ode_info["transformed_solutions"][0]["states"].items() %}
      {{state}}[i] = {{ vector_printer.print(state_solution_info["update_expression"], "i", non_vec_vars) }};
          {%- endfor %}
      {%- endfor %}

      // update kernel state variable / compute synaptic conductance
      {%- for convolution, convolution_info in receptor_info["convolutions"].items() %}
      {%- for state_variable_name, state_variable_info in convolution_info["analytic_solution"]["kernel_states"].items() %}
      {{state_variable_name}}[i] = {{ vector_printer.print(state_variable_info["update_expression"], "i", non_vec_vars) }};
          {%- if convolution_info["spikes"]["name"] == self_spikes_name %}
      {{state_variable_name}}[i] += self_spikes[i] * {{ vector_printer.print(state_variable_info["init_expression"], "i", non_vec_vars) }};
          {%- else %}
      {{state_variable_name}}[i] += s_val[i] * {{ vector_printer.print(state_variable_info["init_expression"], "i", non_vec_vars) }};
          {%- endif %}
      {%- endfor %}
      {%- endfor %}

      // total current
      // this expression should be the transformed inline expression

      i_tot_{{receptor_name}}[i] = {{ vector_printer.print(receptor_info["root_expression"], "i", non_vec_vars) }};

      // derivative of that expression
      // voltage derivative of total current
      // compute derivative with respect to current with sympy
      {{ cm_scalar_t }} d_i_tot_dv = {{ vector_printer.print(receptor_info["inline_derivative"], "i", non_vec_vars) }};

      // for numerical integration
      g_vals_{{receptor_name}}[i] = -d_i_tot_dv;
      i_vals_{{receptor_name}}[i] = i_tot_{{receptor_name}}[i] - d_i_tot_dv * v_comp;
    }

  if(con_area_count > 0){
      for(std::size_t con_area_index = 0; con_area_index < con_area_count-1; con_area_index++){
          std::size_t con_start = con_area[con_area_index].first;
          std::size_t con_end = con_area[con_area_index+1].first;
          int offset = con_area[con_area_index].second;

          #pragma omp simd
          for(std::size_t rec_id = con_start; rec_id < con_end; rec_id++){
              g_val[rec_id + offset] += g_vals_{{receptor_name}}[rec_id];
              i_val[rec_id + offset] += i_vals_{{receptor_name}}[rec_id];
          }
      }

      std::size_t con_start = con_area[con_area_count-1].first;
      int offset = con_area[con_area_count-1].second;

      #pragma omp simd
      for(std::size_t rec_id = con_start; rec_id < neuron_{{ receptor_name }}_receptor_count; rec_id++){
          g_val[rec_id + offset] += g_vals_{{receptor_name}}[rec_id];
          i_val[rec_id + offset] += i_vals_{{receptor_name}}[rec_id];
      }
  }

  {%- if receptor_info["Blocks"] and receptor_info["Blocks"]["UpdateBlock"] %}
  f_update();
  {%- endif %}
}

