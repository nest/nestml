  for(std::size_t i = 0; i < neuron_{{ continuous_name }}_continuous_input_count; i++){
     // user declared internals in order they were declared
    {%- for internal_name, internal_declaration in continuous_info["Internals"] %}
    {{internal_name}}[i] = {{ vector_printer.print(internal_declaration.get_expression(), "i", non_vec_vars) }};
  {%- endfor %}

        // set propagators to ode toolbox returned value
  {%- for convolution, convolution_info in continuous_info["convolutions"].items() %}
  {%- for state_variable_name, state_variable_info in convolution_info["analytic_solution"]["propagators"].items()%}
    {{state_variable_name}}[i] = {{ vector_printer.print(state_variable_info["init_expression"], "i", non_vec_vars) }};
  {%- endfor %}
  {%- endfor %}

    // initial values for kernel state variables, set to zero
  {%- for convolution, convolution_info in continuous_info["convolutions"].items() %}
  {%- for state_variable_name, state_variable_info in convolution_info["analytic_solution"]["kernel_states"].items()%}
    {{state_variable_name}}[i] = 0;
  {%- endfor %}
  {%- endfor %}

    {% for port_name, port_info in continuous_info["Continuous"].items() %}
    {{port_name}}_[i]->clear();
    {% endfor %}
  }

  con_area.clear();
  if(neuron_{{ continuous_name }}_continuous_input_count){
      int con_end_index = int(compartment_association[0]);
      con_area.push_back(std::pair< std::size_t, int >(0, con_end_index));
      for(std::size_t con_in_id = 1; con_in_id < neuron_{{ continuous_name }}_continuous_input_count; con_in_id++){
          if(!(compartment_association[con_in_id] == size_t(int(con_in_id) + con_end_index))){
              con_end_index = int(compartment_association[con_in_id]) - int(con_in_id);
              con_area.push_back(std::pair< std::size_t, int >(con_in_id, con_end_index));
          }
      }
  }
}

void nest::{{continuous_name}}{{cm_unique_suffix}}::f_numstep(const std::vector< {{ cm_scalar_t }} >& shared_v_comp, const long& lag {% for ode in continuous_info["Dependencies"]["concentrations"] %}, const std::vector< {{ cm_scalar_t }} >& shared_{{ode.lhs.name}}{% endfor %}{% if continuous_info["Dependencies"]["receptors"]|length %}
                        {% endif %}{% for inline in continuous_info["Dependencies"]["receptors"] %}, const std::vector< {{ cm_scalar_t }} >& shared_{{inline.variable_name}}{% endfor %}{% if continuous_info["Dependencies"]["channels"]|length %}
                        {% endif %}{% for inline in continuous_info["Dependencies"]["channels"] %}, const std::vector< {{ cm_scalar_t }} >& shared_{{inline.variable_name}}{% endfor %}{% if continuous_info["Dependencies"]["continuous"]|length %}
                        {% endif %}{% for inline in continuous_info["Dependencies"]["continuous"] %}, const std::vector< {{ cm_scalar_t }} >& shared_{{inline.variable_name}}{% endfor %}
                        , std::vector< {{ cm_scalar_t }} >& i_val, std::vector< {{ cm_scalar_t }} >& g_val)
{

    {% if "time_resolution_var" in continuous_info %}
    {{ cm_scalar_t }} {{ printer_no_origin.print(continuous_info["time_resolution_var"]) }} = Time::get_resolution().get_ms();
    {% endif %}

    double self_spikes = *self_spikes_p;

    {% for port_name, port_info in continuous_info["Continuous"].items() %}
    std::vector< {{ cm_scalar_t }} > {{ port_name }}(neuron_{{ continuous_name }}_continuous_input_count, 0.);
    {% endfor %}
    #pragma omp simd
    for(std::size_t i = 0; i < neuron_{{ continuous_name }}_continuous_input_count; i++){
        {% for port_name, port_info in continuous_info["Continuous"].items() %}
        {{ port_name }}[i] = {{ port_name }}_[i]->get_value( lag );
        {% endfor %}
    }

    {%- for function in continuous_info["Functions"] %}
    {{render_lambda(function, printer_no_origin)}}
    {%- endfor %}

  std::size_t con_area_count = con_area.size();
  if(con_area_count > 0){
      for(std::size_t con_area_index = 0; con_area_index < con_area_count-1; con_area_index++){
          std::size_t con_start = con_area[con_area_index].first;
          std::size_t con_end = con_area[con_area_index+1].first;
          int offset = con_area[con_area_index].second;
          #pragma omp simd
          for(std::size_t con_in_id = con_start; con_in_id < con_end; con_in_id++){
              v_comp_con_in_[con_in_id] = shared_v_comp[con_in_id + offset];
              {%- for ode in continuous_info["Dependencies"]["concentrations"] %}
              dep_conc_{{ode.lhs.name}}_con_in_[con_in_id] = shared_{{ode.lhs.name}}[con_in_id + offset];
              {%- endfor %}
              {%- for inline in continuous_info["Dependencies"]["receptors"] %}
              dep_rec_{{inline.variable_name}}_con_in_[con_in_id] = shared_{{inline.variable_name}}[con_in_id + offset];
              {%- endfor %}
              {%- for inline in continuous_info["Dependencies"]["channels"] %}
              dep_chan_{{inline.variable_name}}_con_in_[con_in_id] = shared_{{inline.variable_name}}[con_in_id + offset];
              {%- endfor %}
              {%- for inline in continuous_info["Dependencies"]["continuous"] %}
              dep_con_in_{{inline.variable_name}}_con_in_[con_in_id] = shared_{{inline.variable_name}}[con_in_id + offset];
              {%- endfor %}
          }
      }
      std::size_t con_start = con_area[con_area_count-1].first;
      int offset = con_area[con_area_count-1].second;
      #pragma omp simd
      for(std::size_t con_in_id = con_start; con_in_id < neuron_{{ continuous_name }}_continuous_input_count; con_in_id++){
          v_comp_con_in_[con_in_id] = shared_v_comp[con_in_id + offset];
          {%- for ode in continuous_info["Dependencies"]["concentrations"] %}
          dep_conc_{{ode.lhs.name}}_con_in_[con_in_id] = shared_{{ode.lhs.name}}[con_in_id + offset];
          {%- endfor %}
          {%- for inline in continuous_info["Dependencies"]["receptors"] %}
          dep_rec_{{inline.variable_name}}_con_in_[con_in_id] = shared_{{inline.variable_name}}[con_in_id + offset];
          {%- endfor %}
          {%- for inline in continuous_info["Dependencies"]["channels"] %}
          dep_chan_{{inline.variable_name}}_con_in_[con_in_id] = shared_{{inline.variable_name}}[con_in_id + offset];
          {%- endfor %}
          {%- for inline in continuous_info["Dependencies"]["continuous"] %}
          dep_con_in_{{inline.variable_name}}_con_in_[con_in_id] = shared_{{inline.variable_name}}[con_in_id + offset];
          {%- endfor %}
      }
  }

  #pragma omp simd
  for(std::size_t i = 0; i < neuron_{{ continuous_name }}_continuous_input_count; i++){
            {{ cm_scalar_t }} v_comp = v_comp_con_in_[i];
            {% for ode in continuous_info["Dependencies"]["concentrations"] %}
            {{ cm_scalar_t }} {{ode.lhs.name}} = dep_conc_{{ode.lhs.name}}_con_in_[i];
            {% endfor %}
            {% for inline in continuous_info["Dependencies"]["receptors"] %}
            {{ cm_scalar_t }} {{inline.variable_name}} = dep_rec_{{inline.variable_name}}_con_in_[i];
            {% endfor %}
            {% for inline in continuous_info["Dependencies"]["channels"] %}
            {{ cm_scalar_t }} {{inline.variable_name}} = dep_chan_{{inline.variable_name}}_con_in_[i];
            {% endfor %}
            {% for inline in continuous_info["Dependencies"]["continuous"] %}
            {{ cm_scalar_t }} {{inline.variable_name}} = dep_con_in_{{inline.variable_name}}_con_in_[i];
            {% endfor %}

        {%- for replacement, expression in continuous_info["cse_function_replacements"].items() %}
            {{ cm_scalar_t }} {{ replacement }} = {{ vector_printer.print(expression, "i", non_vec_vars) }};
        {%- endfor %}
        {%- for replacement, expression in continuous_info["cse_body_replacements"].items() %}
            {{ cm_scalar_t }} {{ replacement }} = {{ vector_printer.print(expression, "i", non_vec_vars) }};
        {%- endfor %}

        {%- for variable_info in continuous_info["SecondaryInlineExpressions"] %}
        {%- if variable_info.is_recordable %}
        {%- set variable = variable_info.variable_name %}
        {%- set rhs_expression = variable_info.expression %}
        {{ variable }}[i] = {{ vector_printer.print(rhs_expression, "i", non_vec_vars) }};
        {%- endif %}
        {%- endfor %}

      {%- for convolution, convolution_info in continuous_info["convolutions"].items() %}
      {%- for state_variable_name, state_variable_info in convolution_info["analytic_solution"]["kernel_states"].items() %}
      {{state_variable_name}}[i] = {{ vector_printer.print(state_variable_info["update_expression"], "i", non_vec_vars) }};
      {{state_variable_name}}[i] += self_spikes * {{ vector_printer.print(state_variable_info["init_expression"], "i", non_vec_vars) }};
      {%- endfor %}
      {%- endfor %}

      //update ODE state variable
      {%- for ode_variable, ode_info in continuous_info["ODEs"].items() %}
          {%- for propagator, propagator_info in ode_info["transformed_solutions"][0]["propagators"].items() %}
      {{ cm_scalar_t }} {{ propagator }} = {{ vector_printer.print(propagator_info["init_expression"], "i", non_vec_vars) }};
          {%- endfor %}
          {%- for state, state_solution_info in ode_info["transformed_solutions"][0]["states"].items() %}
      {{state}}[i] = {{ vector_printer.print(state_solution_info["update_expression"], "i", non_vec_vars) }};
          {%- endfor %}
      {%- endfor %}

      // total current
      // this expression should be the transformed inline expression
      i_tot_{{continuous_name}}[i] = {{ vector_printer.print(continuous_info["root_expression"], "i", non_vec_vars) }};

      // derivative of that expression
      // voltage derivative of total current
      // compute derivative with respect to current with sympy
      {{ cm_scalar_t }} d_i_tot_dv = {{ vector_printer.print(continuous_info["inline_derivative"], "i", non_vec_vars) }};

      // for numerical integration
      g_vals_{{continuous_name}}[i] = -d_i_tot_dv;
      i_vals_{{continuous_name}}[i] = i_tot_{{continuous_name}}[i] - d_i_tot_dv * v_comp;
  }

  if(con_area_count > 0){
      for(std::size_t con_area_index = 0; con_area_index < con_area_count-1; con_area_index++){
          std::size_t con_start = con_area[con_area_index].first;
          std::size_t con_end = con_area[con_area_index+1].first;
          int offset = con_area[con_area_index].second;

          #pragma omp simd
          for(std::size_t con_in_id = con_start; con_in_id < con_end; con_in_id++){
              g_val[con_in_id + offset] += g_vals_{{continuous_name}}[con_in_id];
              i_val[con_in_id + offset] += i_vals_{{continuous_name}}[con_in_id];
          }
      }

      std::size_t con_start = con_area[con_area_count-1].first;
      int offset = con_area[con_area_count-1].second;

      #pragma omp simd
      for(std::size_t con_in_id = con_start; con_in_id < neuron_{{ continuous_name }}_continuous_input_count; con_in_id++){
          g_val[con_in_id + offset] += g_vals_{{continuous_name}}[con_in_id];
          i_val[con_in_id + offset] += i_vals_{{continuous_name}}[con_in_id];
      }
  }

  {%- if continuous_info["Blocks"] and continuous_info["Blocks"]["UpdateBlock"] %}
  f_update();
  {%- endif %}
}

