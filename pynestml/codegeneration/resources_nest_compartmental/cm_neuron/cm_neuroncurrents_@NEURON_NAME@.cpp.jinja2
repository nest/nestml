{
    {%- if continuous_info["Blocks"] and continuous_info["Blocks"]["UpdateBlock"] %}
    {{ cm_scalar_t }} __resolution = Time::get_resolution().get_ms();
    for(std::size_t i = 0; i < neuron_{{ continuous_name }}_continuous_input_count; i++){
        {%- set function = continuous_info["Blocks"]["UpdateBlock"] %}
        {%-   filter indent(2,True) %}
        {%-   with ast = function.get_stmts_body() %}
        {%- set printer = vector_printer.printer(black_list = non_vec_vars) %}
        {%-     include "cm_directives_cpp/StmtsBody.jinja2" %}
        {%-   endwith %}
        {%-   endfilter %}
    }
    {%- endif %}
}

