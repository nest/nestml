#ifndef FASTEXP_V4_{{cm_unique_suffix | upper }}_H
#define FASTEXP_V4_{{cm_unique_suffix | upper }}_H

#include <algorithm>
#include <cmath>

namespace nest
{

#pragma omp declare simd
__attribute__( ( always_inline ) ) inline float
cm_fast_propagator_exp( const float x )
{
  // Degree-5 polynomial approximation of exp(x) on [-2, 0].
  constexpr float c0 = 9.999833698215347955e-01f;
  constexpr float c1 = 9.993709968710966507e-01f;
  constexpr float c2 = 4.961277470116420840e-01f;
  constexpr float c3 = 1.578134199162989360e-01f;
  constexpr float c4 = 3.218380466140600971e-02f;
  constexpr float c5 = 3.214600822495845053e-03f;

  // Keep the evaluation inside the calibrated propagator interval while
  // preserving x < 0 (to match propagator semantics).
  const float xc = std::min( -1.0e-8f, std::max( -2.0f, x ) );

  return c0 + xc * ( c1 + xc * ( c2 + xc * ( c3 + xc * ( c4 + xc * c5 ) ) ) );
}

#pragma omp declare simd
__attribute__( ( always_inline ) ) inline double
cm_fast_propagator_exp( const double x )
{
  // Degree-5 polynomial approximation of exp(x) on [-2, 0].
  constexpr double c0 = 9.999833698215347955e-01;
  constexpr double c1 = 9.993709968710966507e-01;
  constexpr double c2 = 4.961277470116420840e-01;
  constexpr double c3 = 1.578134199162989360e-01;
  constexpr double c4 = 3.218380466140600971e-02;
  constexpr double c5 = 3.214600822495845053e-03;

  // Keep the evaluation inside the calibrated propagator interval while
  // preserving x < 0 (to match propagator semantics).
  const double xc = std::min( -1.0e-12, std::max( -2.0, x ) );

  return c0 + xc * ( c1 + xc * ( c2 + xc * ( c3 + xc * ( c4 + xc * c5 ) ) ) );
}

} // namespace nest

#endif
