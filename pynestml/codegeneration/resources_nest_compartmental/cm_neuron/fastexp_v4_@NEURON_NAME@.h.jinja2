#ifndef FASTEXP_V4_{{cm_unique_suffix | upper }}_H
#define FASTEXP_V4_{{cm_unique_suffix | upper }}_H

#include <cmath>
#include <stdexcept>

namespace nest
{

// Fast propagator exp approximation for x in [-2, 0).
// Outside this range we either fall back (x < -2) or throw (x >= 0).
#if defined(__has_cpp_attribute)
#if __has_cpp_attribute(unlikely)
#define CM_UNLIKELY [[unlikely]]
#else
#define CM_UNLIKELY
#endif
#else
#define CM_UNLIKELY
#endif

inline float
cm_fast_propagator_exp( const float x )
{
  if ( x < -2.0f ) CM_UNLIKELY
  {
    return std::expf( x );
  }
  if ( x >= 0.0f ) CM_UNLIKELY
  {
    throw std::domain_error( "cm_fast_propagator_exp expects x < 0" );
  }

  // Degree-5 polynomial approximation of exp(x) on [-2, 0].
  constexpr float c0 = 9.999604420234498026e-01f;
  constexpr float c1 = 9.991461618881908313e-01f;
  constexpr float c2 = 4.955644075124273074e-01f;
  constexpr float c3 = 1.572688083174653417e-01f;
  constexpr float c4 = 3.196651681886048674e-02f;
  constexpr float c5 = 3.185568834547398802e-03f;

  return c0 + x * ( c1 + x * ( c2 + x * ( c3 + x * ( c4 + x * c5 ) ) ) );
}

inline double
cm_fast_propagator_exp( const double x )
{
  if ( x < -2.0 ) CM_UNLIKELY
  {
    return std::exp( x );
  }
  if ( x >= 0.0 ) CM_UNLIKELY
  {
    throw std::domain_error( "cm_fast_propagator_exp expects x < 0" );
  }

  // Degree-5 polynomial approximation of exp(x) on [-2, 0].
  constexpr double c0 = 9.999604420234498026e-01;
  constexpr double c1 = 9.991461618881908313e-01;
  constexpr double c2 = 4.955644075124273074e-01;
  constexpr double c3 = 1.572688083174653417e-01;
  constexpr double c4 = 3.196651681886048674e-02;
  constexpr double c5 = 3.185568834547398802e-03;

  return c0 + x * ( c1 + x * ( c2 + x * ( c3 + x * ( c4 + x * c5 ) ) ) );
}

#undef CM_UNLIKELY

} // namespace nest

#endif
