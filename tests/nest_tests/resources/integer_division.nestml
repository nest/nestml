model integer_division_test:
    state:
        x integer = 5
        y real = pi
        z real = pi
        p real = pi
        q real = pi
        r integer = 5
        neg1 integer = -5
        neg2 integer = -5
        neg3 integer = -5

    update:
        x /= 2
        y /= 2
        z //= 2
        p = p / 2
        q = q // 2
        r = r // 2
        neg1 /= 2
        neg2 //= 2
        neg3 //= -2
