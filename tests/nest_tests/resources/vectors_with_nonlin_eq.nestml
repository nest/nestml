model vectors_with_nonlin_eq:

    state:
        foo real = 42
        I_NMDA_AMPA_delay_buf[delay_steps] pA = 0 pA
        I_NMDA_AMPA_idx integer = 0

    equations:
        foo' = -foo**2 / tau

    parameters:
        tau ms = 4 ms
        delay_steps integer = 10

    output:
        spike

    update:
        integrate_odes()
        if I_NMDA_AMPA_idx % 2 == 0:
            I_NMDA_AMPA_delay_buf[I_NMDA_AMPA_idx] = 42 pA
        else:
            I_NMDA_AMPA_delay_buf[I_NMDA_AMPA_idx] = foo - 42 pA

        I_NMDA_AMPA_idx += 1
        I_NMDA_AMPA_idx = I_NMDA_AMPA_idx % delay_steps
