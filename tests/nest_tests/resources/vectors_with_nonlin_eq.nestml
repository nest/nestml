model vectors_with_nonlin_eq:

    state:
        x real = 42
        y real = 42
        x_buf[buf_len] real = 0
        y_buf[buf_len] real = 0
        buf_idx integer = 0

    equations:
        recordable inline rec_inline real = e * x * y
        x' = -x / tau
        y' = -y**2 / tau

    parameters:
        tau ms = 4 ms
        buf_len integer = 10

    output:
        spike

    update:
        x_buf[buf_idx] = x
        y_buf[buf_idx] = y

        buf_idx = (buf_idx + 1) % buf_len

        integrate_odes()
