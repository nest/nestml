model integrate_odes_test_spikes:
    state:
        x real = 0.
        do_integrate_odes boolean = true

    equations:
        x' = -x / (1E99 ms) + spikes_in_port

    input:
        spikes_in_port <- spike

    update:
        if do_integrate_odes:
            integrate_odes(x)
