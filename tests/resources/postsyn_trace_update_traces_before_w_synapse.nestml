# You should have received a copy of the GNU General Public License
# along with NEST.  If not, see <http://www.gnu.org/licenses/>.
#
model postsyn_trace_synapse:
    state:
        w real = 1
        zp_trace real = 0.      # z_plus

    parameters:
        d ms = 1 ms

        tau_zp ms = 50 ms
        Zp real = 0.2
        learning_rate real = 1E-3

    equations:
        zp_trace' = -zp_trace / tau_zp

    input:
        pre_spikes <- spike
        post_spikes <- spike

    output:
        spike(weight real, delay ms)

    onReceive(post_spikes, priority=1):
        zp_trace += 1    # Zp * (1 - zp_trace)

        w += learning_rate * zp_trace

    onReceive(pre_spikes, priority=2):
        emit_spike(w, d)

    update:
        integrate_odes()
