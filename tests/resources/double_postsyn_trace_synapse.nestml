model double_postsyn_trace_synapse:
    state:
        w real = 1
        zm_trace real = 0.      # z_minus
        zp_trace real = 0.      # z_plus

    parameters:
        tau_zm ms = 100 ms
        tau_zp ms = 50 ms
        Zm real = 0.1
        Zp real = 0.2

        update_order_w_before_trace boolean = false

    equations:
        zm_trace' = -zm_trace / tau_zm
        zp_trace' = -zp_trace / tau_zp

    input:
        pre_spikes <- spike
        post_spikes <- spike

    output:
        spike

    onReceive(post_spikes, priority=1):
        if update_order_w_before_trace:
            w += zp_trace * zm_trace

            zp_trace += Zp * (1 - zp_trace)
            zm_trace += Zm * (1 - zm_trace)
        else:
            zp_trace += Zp * (1 - zp_trace)
            zm_trace += Zm * (1 - zm_trace)

            w += zp_trace * zm_trace

    onReceive(pre_spikes, priority=2):
        emit_spike(w)

    update:
        integrate_odes()
